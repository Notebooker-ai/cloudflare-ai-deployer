---
import Base from '../layouts/Base.astro';
import TokenGate from '../components/TokenGate.tsx';
import { getSession } from '../lib/auth';

// If already authenticated, jump straight to the dashboard.
const session = await getSession(Astro);
if (session) return Astro.redirect('/dashboard');
---

<Base>
  <section class="mx-auto max-w-[110ch] px-4 pt-12 pb-10 sm:px-6 md:pt-20">
    <h1 class="max-w-3xl text-3xl leading-tight font-bold md:text-4xl">
      Deploy your own AI endpoint.<br />
      <span class="text-accent">On your own Cloudflare.</span>
    </h1>
    <p class="mt-5 max-w-2xl text-fg1">
      An OpenAI-compatible API backed by Cloudflare Workers AI — chat, speech, vision, embeddings —
      deployed to your account in one click. Pick your models, test it right here, copy your key.
      No signup, no database, nothing stored on our side.
    </p>
  </section>

  <section class="mx-auto max-w-[110ch] px-4 pb-16 sm:px-6">
    <TokenGate client:load />
  </section>
</Base>
