---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Open Notebooker — deploy your own AI endpoint',
  description = 'Deploy an OpenAI-compatible AI endpoint on your own Cloudflare account in one click. Try out your own AI with Notebooker.ai.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent dark-mode flash. -->
    <script is:inline>
      if (
        localStorage.getItem('darkMode') === 'true' ||
        (!localStorage.getItem('darkMode') &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.setAttribute('data-webtui-theme', 'dark');
      }
    </script>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 border-b-2 border-fg0 bg-bg0/95 backdrop-blur">
      <div class="mx-auto flex max-w-[110ch] items-center justify-between px-4 py-2 sm:px-6">
        <a href="/" class="flex items-center gap-2 !text-fg0 hover:!no-underline">
          <span class="font-bold">Notebooker.ai</span>
          <span is-="badge" variant-="foreground0">OPEN</span>
        </a>
        <button id="theme-toggle" size-="small" box-="square" aria-label="Toggle dark mode">
          [ theme ]
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t-2 border-bg2">
      <div
        class="mx-auto flex max-w-[110ch] flex-wrap items-center justify-between gap-3 px-4 py-6 text-fg2 sm:px-6"
      >
        <span>
          Try out your own AI with <a href="https://notebooker.ai">Notebooker.ai</a>. Your keys ·
          your account · your data.
        </span>
        <a href="https://github.com/Notebooker-ai/cloudflare-ai-deployer" target="_blank" rel="noreferrer">
          [source: github]
        </a>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const el = document.documentElement;
        const isDark = el.getAttribute('data-webtui-theme') === 'dark';
        if (isDark) el.removeAttribute('data-webtui-theme');
        else el.setAttribute('data-webtui-theme', 'dark');
        localStorage.setItem('darkMode', String(!isDark));
      });
    </script>
  </body>
</html>
