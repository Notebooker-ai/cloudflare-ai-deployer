---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Open Notebooker — deploy your own AI endpoint',
  description = 'Deploy an OpenAI-compatible AI endpoint on your own Cloudflare account in one click. Try out your own AI with Notebooker.ai.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..700;1,6..72,300..700&family=Source+Sans+3:wght@400..700&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent dark-mode flash. -->
    <script is:inline>
      if (
        localStorage.getItem('darkMode') === 'true' ||
        (!localStorage.getItem('darkMode') &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-paper text-ink dark:bg-night dark:text-ink-invert font-sans antialiased">
    <header
      class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur-lg dark:border-line-dark dark:bg-night/90"
    >
      <div class="mx-auto flex max-w-[1180px] items-center justify-between px-4 py-3 sm:px-6">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo-wordmark.svg" alt="Notebooker.ai" class="h-8 dark:hidden" />
          <img src="/logo-wordmark-dark.svg" alt="Notebooker.ai" class="hidden h-8 dark:block" />
          <span class="font-sans text-[13px] font-semibold uppercase tracking-wide text-ink-faint"
            >Open</span
          >
        </a>
        <button
          id="theme-toggle"
          class="rounded-[3px] border border-line px-3 py-1.5 text-[13px] font-semibold text-ink-soft transition-colors hover:border-accent hover:text-accent dark:border-line-dark dark:text-ink-softinvert"
          aria-label="Toggle dark mode"
        >
          Theme
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-line dark:border-line-dark">
      <div
        class="mx-auto flex max-w-[1180px] flex-wrap items-center justify-between gap-3 px-4 py-8 text-[13px] text-ink-faint sm:px-6 dark:text-ink-softinvert"
      >
        <span>
          Try out your own AI with <a
            href="https://notebooker.ai"
            class="text-accent hover:underline dark:text-accent-invert">Notebooker.ai</a
          >. Your keys · your account · your data.
        </span>
        <a
          href="https://github.com/Notebooker-ai/cloudflare-ai-deployer"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-1.5 text-ink-soft hover:text-accent dark:text-ink-softinvert dark:hover:text-accent-invert"
        >
          <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"
            ><path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path></svg
          >
          Source on GitHub
        </a>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('darkMode', String(isDark));
      });
    </script>
  </body>
</html>
