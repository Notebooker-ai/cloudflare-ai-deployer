---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Open Notebooker — deploy your own AI endpoint',
  description = 'Deploy an OpenAI-compatible AI endpoint on your own Cloudflare account in one click. Try out your own AI with Notebooker.ai.',
} = Astro.props;

// Stock WebTUI light/dark plus every installed theme variant.
const THEMES: Array<[value: string, label: string]> = [
  ['light', 'light'],
  ['dark', 'dark'],
  ['catppuccin-latte', 'catppuccin latte'],
  ['catppuccin-frappe', 'catppuccin frappé'],
  ['catppuccin-macchiato', 'catppuccin macchiato'],
  ['catppuccin-mocha', 'catppuccin mocha'],
  ['everforest-light', 'everforest light'],
  ['everforest-dark', 'everforest dark'],
  ['gruvbox-light', 'gruvbox light'],
  ['gruvbox-dark', 'gruvbox dark'],
  ['nord', 'nord'],
  ['osmium', 'osmium'],
  ['vitesse-light', 'vitesse light'],
  ['vitesse-dark', 'vitesse dark'],
  ['vitesse-black', 'vitesse black'],
];

const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {isProd && (
      <!-- Google Tag Manager -->
      <script is:inline>{`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KJSQS68F');`}</script>
      <!-- End Google Tag Manager -->
    )}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Apply the saved theme before paint (no flash). -->
    <script is:inline>
      (() => {
        // Default to catppuccin mocha unless the visitor has chosen a theme.
        const theme = localStorage.getItem('webtui-theme') || 'catppuccin-mocha';
        if (theme !== 'light') document.documentElement.setAttribute('data-webtui-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    {isProd && (
      <!-- Google Tag Manager (noscript) -->
      <noscript>
        <iframe
          src="https://www.googletagmanager.com/ns.html?id=GTM-KJSQS68F"
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
      <!-- End Google Tag Manager (noscript) -->
    )}
    <header class="sticky top-0 z-50 bg-bg0 shadow-[0_1px_0_0_var(--background2)]">
      <div class="mx-auto flex max-w-[110ch] items-center justify-between gap-4 px-4 py-2 sm:px-6">
        <a href="/" class="flex items-center gap-2 !text-fg0 !no-underline">
          <span class="font-bold">Notebooker.ai</span>
          <span is-="badge" class="badge-accent">OPEN</span>
        </a>
        <label class="flex items-center gap-2 text-fg2">
          <span aria-hidden="true">&#xf1fc;</span>
          <select id="theme-select" class="!w-auto" aria-label="Theme">
            {THEMES.map(([value, label]) => <option value={value}>{label}</option>)}
          </select>
        </label>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 shadow-[0_-1px_0_0_var(--background2)]">
      <div
        class="mx-auto flex max-w-[110ch] flex-wrap items-center justify-between gap-3 px-4 py-6 text-fg2 sm:px-6"
      >
        <span>
          Try out your own AI with <a href="https://notebooker.ai">Notebooker.ai</a>. Your keys ·
          your account · your data.
        </span>
        <a href="https://github.com/Notebooker-ai/cloudflare-ai-deployer" target="_blank" rel="noreferrer">
          &#xf09b; source
        </a>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const select = document.getElementById('theme-select');
        if (!select) return;
        select.value = document.documentElement.getAttribute('data-webtui-theme') || 'light';
        if (![...select.options].some((o) => o.value === select.value)) select.value = 'catppuccin-mocha';
        select.addEventListener('change', () => {
          const theme = select.value;
          if (theme === 'light') document.documentElement.removeAttribute('data-webtui-theme');
          else document.documentElement.setAttribute('data-webtui-theme', theme);
          localStorage.setItem('webtui-theme', theme);
        });
      })();
    </script>
  </body>
</html>
